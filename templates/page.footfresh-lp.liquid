<script>
  function setLang(lang) {
    document.querySelectorAll('.lang-btn').forEach(function(btn) {
      btn.classList.remove('active');
      if (btn.textContent.trim() === (lang === 'en' ? 'EN' : lang === 'zh' ? '中文' : '日本語')) {
        btn.classList.add('active');
      }
    });

    document.querySelectorAll('[data-lang]').forEach(function(el) {
      el.classList.toggle('active', el.getAttribute('data-lang') === lang);
    });
    
    document.documentElement.lang = lang === 'zh' ? 'zh-CN' : lang;
    localStorage.setItem('lp-lang-pop', lang);
  }

  (function() {
    var saved = localStorage.getItem('lp-lang-pop');
    setLang(saved || 'en');
  })();

  var fadeEls = document.querySelectorAll('.fade-up');
  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.1 });
  fadeEls.forEach(function(el) { observer.observe(el); });
</script>


<script>
  const ffTiers = [
    { min: 1, max: 1, price: 44.94 },
    { min: 2, max: 2, price: 42.69 },
    { min: 3, max: 4, price: 40.45 },
    { min: 5, max: 99, price: 38.20 }
  ];

  function updateFFQty(idx, change) {
    const input = document.getElementById('product-qty-' + idx);
    let val = parseInt(input.value) + change;
    if (val < 1) val = 1;
    if (val > 10) val = 10;
    input.value = val;
    renderFFDiscount(idx, val);
  }

  function renderFFDiscount(idx, qty) {
    const tableEl = document.getElementById('ff-discount-table-' + idx);
    if(!tableEl) return;
    const tableRows = tableEl.querySelectorAll('tbody tr');
    let currentPrice = 44.94;
    
    tableRows.forEach(row => {
      row.style.background = '#fff';
      row.style.color = '#555';
      const badges = row.querySelectorAll('.badge');
      badges.forEach(badge => {
        badge.style.background = '#f0f0f0';
        badge.style.color = '#888';
      });
      
      const rowQty = parseInt(row.getAttribute('data-qty'));
      let match = false;
      if (qty === 1 && rowQty === 1) match = true;
      if (qty === 2 && rowQty === 2) match = true;
      if (qty >= 3 && qty <= 4 && rowQty === 3) match = true;
      if (qty >= 5 && rowQty === 5) match = true;
      
      if (match) {
        row.style.background = '#ffeef2';
        row.style.color = '#d81b60';
        badges.forEach(badge => {
          badge.style.background = '#e91e63';
          badge.style.color = '#fff';
        });
      }
    });

    const tier = ffTiers.find(t => qty >= t.min && qty <= t.max);
    if (tier) {
      currentPrice = tier.price;
    }
    
    const total = (currentPrice * qty).toFixed(2);
    document.getElementById('ff-total-calc-' + idx).innerHTML = `${currentPrice.toFixed(2)}$ SGD * ${qty} = <span style="font-size:24px;">${total}$ SGD</span>`;
  }

  function addToCartFF(idx) {
    const qty = document.getElementById('product-qty-' + idx).value;
    const variantId = {{ all_products['フットフレッシュ'].first_available_variant.id | default: 'null' }};
    
    if(!variantId) { 
      alert('商品のVariant IDが見つかりません。'); 
      return; 
    }
    
    const btns = document.querySelectorAll('#order-section-' + idx + ' .cta-btn');
    btns.forEach(btn => {
      btn.innerHTML = 'Adding...';
      btn.disabled = true;
    });

    fetch('/cart/clear.js', { method: 'POST' })
    .then(() => fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        items: [{
          id: variantId,
          quantity: parseInt(qty)
        }]
      })
    }))
    .then(res => res.json())
    .then(data => {
            let locale = 'ja';
      let activeLangBtn = document.querySelector('.lang-btn.active');
      if (activeLangBtn) {
        if (activeLangBtn.innerText.includes('EN')) locale = 'en';
        else if (activeLangBtn.innerText.includes('中文')) locale = 'zh-CN';
      }
      window.location.href = '/checkout?locale=' + locale;
    }).catch(err => {
      alert('エラーが発生しました');
      btns.forEach(btn => {
        btn.innerHTML = '💖 Error';
      });
    });
  }

  // Stock dynamically updates
  function updateStock() {
    const now = new Date();
    // seconds since midnight local time
    const secondsSinceMidnight = now.getHours() * 3600 + now.getMinutes() * 60 + now.getSeconds();
    
    // We want stock to be 30 at 0:00, and go down to 3 at 23:59:59 (so it sells 27 items per day)
    // 86400 seconds / 27 = 3200 seconds per item
    let stock = 30 - Math.floor(secondsSinceMidnight / 3200);
    if (stock < 3) stock = 3; 
    if (stock > 30) stock = 30;
    
    document.querySelectorAll('.dynamic-stock').forEach(el => {
      el.innerText = stock;
    });
    const stockBarFill = document.getElementById('dynamic-stock-bar');
    if (stockBarFill) {
      stockBarFill.style.width = ((stock / 30) * 100) + '%';
    }
  }

  // Init
  document.addEventListener('DOMContentLoaded', () => {
    // initial renders
    renderFFDiscount(1, 1);
    renderFFDiscount(2, 1);
    
    // update stock initially and every 1 minute
    updateStock();
    setInterval(updateStock, 60000);
  });

    // ===== 在庫数の自動減少スクリプト =====
    function updateDynamicStock() {
      var now = new Date();
      var h = now.getHours();
      var m = now.getMinutes();
      var s = now.getSeconds();
      
      var elapsedSeconds = (h * 3600) + (m * 60) + s;
      var totalSeconds = 24 * 3600;
      
      var maxStock = 100;
      var minStock = 15;
      var currentStock = maxStock - Math.floor((elapsedSeconds / totalSeconds) * (maxStock - minStock));
      
      if (currentStock < minStock) currentStock = minStock;
      if (currentStock > maxStock) currentStock = maxStock;
      
      var stockElements = document.querySelectorAll('.dynamic-stock');
      stockElements.forEach(function(el) {
        el.textContent = currentStock;
      });
      
      var stockBar = document.getElementById('dynamic-stock-bar');
      if (stockBar) {
        var percentage = (currentStock / 100) * 100;
        stockBar.style.width = percentage + '%';
      }
    }
    
    updateDynamicStock();
    setInterval(updateDynamicStock, 60000);

</script>
