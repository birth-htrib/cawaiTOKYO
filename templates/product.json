    "custom_liquid_6qRpHj": {
      "type": "custom-liquid",
      "name": "t:sections.custom_liquid.name",
      "settings": {
        "title": "",
        "custom_liquid": "<!-- \n  ========================================\n  cutieTOKYO 数量割引表示スクリプト\n  ========================================\n  Shopify管理画面 → オンラインストア → テーマ → カスタマイズ →\n  商品ページ → 「カスタムLiquid」セクションに、このコードを貼り付けてください。\n  \n  ※ 割引率の設定は DISCOUNT_TIERS 配列を編集してください。\n-->\n\n<style>\n  /* ===== 割引テーブル ===== */\n  .qty-discount-wrapper {\n    margin: 20px 0;\n    font-family: inherit;\n  }\n\n  .qty-discount-title {\n    font-size: 14px;\n    font-weight: 700;\n    margin-bottom: 10px;\n    color: inherit;\n    display: flex;\n    align-items: center;\n    gap: 6px;\n  }\n\n  .qty-discount-title::before {\n    content: '🏷️';\n  }\n\n  .qty-discount-table {\n    width: 100%;\n    border-collapse: collapse;\n    border-radius: 8px;\n    overflow: hidden;\n    border: 1px solid #e5e5e5;\n    font-size: 13px;\n  }\n\n  .qty-discount-table thead th {\n    background: #f5f5f5;\n    padding: 8px 12px;\n    text-align: center;\n    font-weight: 600;\n    font-size: 12px;\n    color: #666;\n    border-bottom: 1px solid #e5e5e5;\n  }\n\n  .qty-discount-table tbody td {\n    padding: 10px 12px;\n    text-align: center;\n    border-bottom: 1px solid #f0f0f0;\n    transition: all 0.2s ease;\n  }\n\n  .qty-discount-table tbody tr:last-child td {\n    border-bottom: none;\n  }\n\n  .qty-discount-table tbody tr.active-tier {\n    background: linear-gradient(135deg, #fff0f6 0%, #ffe8f0 100%);\n  }\n\n  .qty-discount-table tbody tr.active-tier td {\n    font-weight: 600;\n    color: #d63384;\n  }\n\n  .qty-discount-table .discount-badge {\n    display: inline-block;\n    padding: 2px 8px;\n    border-radius: 12px;\n    font-size: 11px;\n    font-weight: 700;\n    background: #f0f0f0;\n    color: #666;\n  }\n\n  .qty-discount-table tr.active-tier .discount-badge {\n    background: linear-gradient(135deg, #ff69b4 0%, #d63384 100%);\n    color: #fff;\n  }\n\n  /* ===== リアルタイム価格計算パネル ===== */\n  .qty-price-panel {\n    margin: 16px 0;\n    padding: 16px;\n    background: linear-gradient(135deg, #fafafa 0%, #f5f5f5 100%);\n    border-radius: 10px;\n    border: 1px solid #e8e8e8;\n    font-size: 14px;\n    transition: all 0.3s ease;\n  }\n\n  .qty-price-panel.has-discount {\n    background: linear-gradient(135deg, #fff8fc 0%, #fff0f6 100%);\n    border-color: #f5c2d7;\n  }\n\n  .qty-price-row {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    padding: 4px 0;\n  }\n\n  .qty-price-row.original-price {\n    color: #888;\n  }\n\n  .qty-price-row.original-price .qty-price-value {\n    text-decoration: line-through;\n  }\n\n  .qty-price-row.discount-amount {\n    color: #d63384;\n    font-weight: 600;\n  }\n\n  .qty-price-divider {\n    border: none;\n    border-top: 1px dashed #ddd;\n    margin: 8px 0;\n  }\n\n  .qty-price-row.total-price {\n    font-size: 18px;\n    font-weight: 700;\n    padding-top: 4px;\n  }\n\n  .qty-price-row.total-price .qty-price-value {\n    color: #d63384;\n  }\n\n  .qty-price-label {\n    display: flex;\n    align-items: center;\n    gap: 4px;\n  }\n\n  .qty-no-discount-msg {\n    text-align: center;\n    color: #999;\n    font-size: 13px;\n    padding: 4px 0;\n  }\n\n  /* ===== アニメーション ===== */\n  .qty-price-panel .qty-price-value {\n    transition: all 0.3s ease;\n  }\n\n  .qty-price-value.price-changed {\n    animation: priceFlash 0.4s ease;\n  }\n\n  @keyframes priceFlash {\n    0% { transform: scale(1); }\n    50% { transform: scale(1.08); color: #d63384; }\n    100% { transform: scale(1); }\n  }\n\n  /* ===== ダークモード対応 ===== */\n  @media (prefers-color-scheme: dark) {\n    .qty-discount-table {\n      border-color: #333;\n    }\n    .qty-discount-table thead th {\n      background: #2a2a2a;\n      color: #aaa;\n      border-bottom-color: #333;\n    }\n    .qty-discount-table tbody td {\n      border-bottom-color: #2a2a2a;\n    }\n    .qty-discount-table tbody tr.active-tier {\n      background: linear-gradient(135deg, #3d1a2e 0%, #2e1525 100%);\n    }\n    .qty-price-panel {\n      background: linear-gradient(135deg, #1e1e1e 0%, #252525 100%);\n      border-color: #333;\n    }\n    .qty-price-panel.has-discount {\n      background: linear-gradient(135deg, #2e1525 0%, #3d1a2e 100%);\n      border-color: #5a2040;\n    }\n  }\n</style>\n\n<script>\n(function() {\n  'use strict';\n\n  // ========================================\n  // 割引設定 - ここを編集して割引率を変更\n  // ========================================\n  // minQty: 適用される最小数量\n  // discountPercent: 割引率（%）\n  const DISCOUNT_TIERS = [\n    { minQty: 1, discountPercent: 0 },\n    { minQty: 2, discountPercent: 5 },\n    { minQty: 3, discountPercent: 10 },\n    { minQty: 5, discountPercent: 15 },\n  ];\n\n  // ========================================\n  // 初期化\n  // ========================================\n  \n  // ページ読み込み完了後に実行\n  function init() {\n    // 必要なDOM要素を取得\n    const quantityInput = document.querySelector('input[name=\"quantity\"]');\n    const addToCartBtn = document.querySelector('.add-to-cart-btn');\n    const priceBlock = document.querySelector('.product-block-price');\n    const quantityBlock = document.querySelector('.product-block-quantity-selector');\n    \n    if (!quantityInput || !addToCartBtn || !priceBlock) {\n      console.warn('[数量割引] 必要なDOM要素が見つかりません');\n      return;\n    }\n\n    // 商品の基本単価を取得（centから通常価格に変換）\n    const unitPrice = getUnitPrice();\n    if (!unitPrice) {\n      console.warn('[数量割引] 単価を取得できませんでした');\n      return;\n    }\n\n    // 通貨フォーマット情報を取得\n    const currencyInfo = getCurrencyInfo();\n\n    // UI要素を作成・挿入\n    const discountTableEl = createDiscountTable(unitPrice, currencyInfo);\n    const pricePanelEl = createPricePanel();\n\n    // 割引テーブルを数量セレクタの前に挿入\n    const insertTarget = quantityBlock || priceBlock;\n    insertTarget.parentNode.insertBefore(discountTableEl, insertTarget.nextSibling);\n    \n    // 価格パネルをAdd to Cartボタンの前に挿入\n    addToCartBtn.parentNode.insertBefore(pricePanelEl, addToCartBtn);\n\n    // 価格更新関数\n    function updatePricing() {\n      const qty = parseInt(quantityInput.value) || 1;\n      const tier = getActiveTier(qty);\n      const discountPercent = tier.discountPercent;\n      const discountedUnitPrice = unitPrice * (1 - discountPercent / 100);\n      const originalTotal = unitPrice * qty;\n      const discountedTotal = discountedUnitPrice * qty;\n      const savingsAmount = originalTotal - discountedTotal;\n\n      // 割引テーブルのアクティブ行を更新\n      updateActiveRow(discountTableEl, qty);\n\n      // 価格パネルを更新\n      updatePricePanel(pricePanelEl, {\n        qty,\n        unitPrice,\n        discountPercent,\n        discountedUnitPrice,\n        originalTotal,\n        discountedTotal,\n        savingsAmount,\n        currencyInfo\n      });\n\n      // Add to Cartボタンの金額を更新\n      updateCartButton(addToCartBtn, discountedTotal, currencyInfo);\n    }\n\n    // イベントリスナーの設定\n    // input イベント（直接入力）\n    quantityInput.addEventListener('input', updatePricing);\n    quantityInput.addEventListener('change', updatePricing);\n\n    // +/- ボタンのクリックを監視\n    const buttons = quantityInput.parentElement.querySelectorAll('button');\n    buttons.forEach(btn => {\n      btn.addEventListener('click', () => {\n        // Alpine.jsの処理が先に実行されるのを待つ\n        setTimeout(updatePricing, 50);\n      });\n    });\n\n    // MutationObserverでinputのvalue変更を監視（Alpine.jsによる変更対応）\n    const observer = new MutationObserver(() => {\n      setTimeout(updatePricing, 50);\n    });\n    observer.observe(quantityInput, { attributes: true, attributeFilter: ['value'] });\n\n    // Alpine.js の x-model 変更も追跡するためのポーリング（フォールバック）\n    let lastQty = parseInt(quantityInput.value) || 1;\n    setInterval(() => {\n      const currentQty = parseInt(quantityInput.value) || 1;\n      if (currentQty !== lastQty) {\n        lastQty = currentQty;\n        updatePricing();\n      }\n    }, 200);\n\n    // 初期表示\n    updatePricing();\n\n    console.log('[数量割引] 初期化完了 - 単価:', formatMoney(unitPrice, currencyInfo));\n  }\n\n  // ========================================\n  // 単価・通貨情報の取得\n  // ========================================\n  \n  function getUnitPrice() {\n    // 方法1: ShopifyAnalytics から取得\n    try {\n      if (window.ShopifyAnalytics && window.ShopifyAnalytics.meta && window.ShopifyAnalytics.meta.product) {\n        const variant = window.ShopifyAnalytics.meta.product.variants[0];\n        if (variant && variant.price) {\n          return variant.price / 100; // centから変換\n        }\n      }\n    } catch(e) {}\n\n    // 方法2: DOM から取得\n    try {\n      const priceEl = document.querySelector('[data-product-price]');\n      if (priceEl) {\n        const priceText = priceEl.textContent.replace(/[^0-9.]/g, '');\n        return parseFloat(priceText);\n      }\n    } catch(e) {}\n\n    // 方法3: meta tag から取得\n    try {\n      const metaPrice = document.querySelector('meta[property=\"og:price:amount\"]');\n      if (metaPrice) {\n        return parseFloat(metaPrice.content);\n      }\n    } catch(e) {}\n\n    return null;\n  }\n\n  function getCurrencyInfo() {\n    let currency = 'SGD';\n    let moneyFormat = '${{amount}} SGD';\n\n    try {\n      if (window.Shopify && window.Shopify.currency && window.Shopify.currency.active) {\n        currency = window.Shopify.currency.active;\n      }\n    } catch(e) {}\n\n    try {\n      const metaCurrency = document.querySelector('meta[property=\"og:price:currency\"]');\n      if (metaCurrency) {\n        currency = metaCurrency.content;\n      }\n    } catch(e) {}\n\n    // 通貨に応じたフォーマット\n    if (currency === 'JPY') {\n      moneyFormat = '¥{{amount}}';\n    } else if (currency === 'SGD') {\n      moneyFormat = '${{amount}} SGD';\n    } else if (currency === 'USD') {\n      moneyFormat = '${{amount}}';\n    }\n\n    return { currency, moneyFormat };\n  }\n\n  // ========================================\n  // 金額フォーマット\n  // ========================================\n\n  function formatMoney(amount, currencyInfo) {\n    const { currency, moneyFormat } = currencyInfo;\n    let formatted;\n    \n    if (currency === 'JPY') {\n      formatted = Math.round(amount).toLocaleString('ja-JP');\n    } else {\n      formatted = amount.toFixed(2);\n    }\n\n    return moneyFormat.replace('{{amount}}', formatted);\n  }\n\n  // ========================================\n  // 割引ティアの取得\n  // ========================================\n\n  function getActiveTier(qty) {\n    let activeTier = DISCOUNT_TIERS[0];\n    for (const tier of DISCOUNT_TIERS) {\n      if (qty >= tier.minQty) {\n        activeTier = tier;\n      }\n    }\n    return activeTier;\n  }\n\n  // ========================================\n  // UI作成: 割引テーブル\n  // ========================================\n\n  function createDiscountTable(unitPrice, currencyInfo) {\n    const wrapper = document.createElement('div');\n    wrapper.className = 'qty-discount-wrapper';\n\n    const title = document.createElement('div');\n    title.className = 'qty-discount-title';\n    title.textContent = 'まとめ買い割引';\n    wrapper.appendChild(title);\n\n    const table = document.createElement('table');\n    table.className = 'qty-discount-table';\n\n    // ヘッダー\n    const thead = document.createElement('thead');\n    thead.innerHTML = `\n      <tr>\n        <th>数量</th>\n        <th>割引率</th>\n        <th>単価</th>\n      </tr>\n    `;\n    table.appendChild(thead);\n\n    // ボディ\n    const tbody = document.createElement('tbody');\n    DISCOUNT_TIERS.forEach((tier, index) => {\n      const tr = document.createElement('tr');\n      tr.dataset.tierIndex = index;\n      tr.dataset.minQty = tier.minQty;\n\n      const discountedPrice = unitPrice * (1 - tier.discountPercent / 100);\n      const nextTier = DISCOUNT_TIERS[index + 1];\n      const qtyLabel = nextTier \n        ? (tier.minQty === nextTier.minQty - 1 ? `${tier.minQty}個` : `${tier.minQty}〜${nextTier.minQty - 1}個`)\n        : `${tier.minQty}個〜`;\n      \n      // 1個の場合は特別な表示\n      if (tier.minQty === 1 && tier.discountPercent === 0) {\n        tr.innerHTML = `\n          <td>${qtyLabel}</td>\n          <td><span class=\"discount-badge\">通常価格</span></td>\n          <td>${formatMoney(discountedPrice, currencyInfo)}</td>\n        `;\n      } else {\n        tr.innerHTML = `\n          <td>${qtyLabel}</td>\n          <td><span class=\"discount-badge\">${tier.discountPercent}% OFF</span></td>\n          <td>${formatMoney(discountedPrice, currencyInfo)}</td>\n        `;\n      }\n\n      tbody.appendChild(tr);\n    });\n    table.appendChild(tbody);\n    wrapper.appendChild(table);\n\n    return wrapper;\n  }\n\n  // ========================================\n  // UI作成: 価格計算パネル\n  // ========================================\n\n  function createPricePanel() {\n    const panel = document.createElement('div');\n    panel.className = 'qty-price-panel';\n    panel.innerHTML = `\n      <div class=\"qty-price-row original-price\" id=\"qty-original-price\" style=\"display: none;\">\n        <span class=\"qty-price-label\">定価</span>\n        <span class=\"qty-price-value\" id=\"qty-original-value\"></span>\n      </div>\n      <div class=\"qty-price-row discount-amount\" id=\"qty-discount-row\" style=\"display: none;\">\n        <span class=\"qty-price-label\">📣 値引き額</span>\n        <span class=\"qty-price-value\" id=\"qty-discount-value\"></span>\n      </div>\n      <hr class=\"qty-price-divider\" id=\"qty-divider\" style=\"display: none;\">\n      <div class=\"qty-price-row total-price\">\n        <span class=\"qty-price-label\">合計金額</span>\n        <span class=\"qty-price-value\" id=\"qty-total-value\"></span>\n      </div>\n      <div class=\"qty-no-discount-msg\" id=\"qty-no-discount\" style=\"display: none;\">\n        2個以上でまとめ買い割引が適用されます ✨\n      </div>\n    `;\n    return panel;\n  }\n\n  // ========================================\n  // UI更新\n  // ========================================\n\n  function updateActiveRow(tableWrapper, qty) {\n    const rows = tableWrapper.querySelectorAll('tbody tr');\n    let activeIndex = 0;\n\n    DISCOUNT_TIERS.forEach((tier, index) => {\n      if (qty >= tier.minQty) {\n        activeIndex = index;\n      }\n    });\n\n    rows.forEach((row, index) => {\n      row.classList.toggle('active-tier', index === activeIndex);\n    });\n  }\n\n  function updatePricePanel(panel, data) {\n    const {\n      qty, unitPrice, discountPercent, discountedUnitPrice,\n      originalTotal, discountedTotal, savingsAmount, currencyInfo\n    } = data;\n\n    const hasDiscount = discountPercent > 0;\n    panel.classList.toggle('has-discount', hasDiscount);\n\n    // 定価行\n    const originalRow = panel.querySelector('#qty-original-price');\n    const originalValue = panel.querySelector('#qty-original-value');\n    originalRow.style.display = hasDiscount ? 'flex' : 'none';\n    if (hasDiscount) {\n      originalValue.textContent = `${formatMoney(unitPrice, currencyInfo)} × ${qty} = ${formatMoney(originalTotal, currencyInfo)}`;\n    }\n\n    // 値引き行\n    const discountRow = panel.querySelector('#qty-discount-row');\n    const discountValue = panel.querySelector('#qty-discount-value');\n    discountRow.style.display = hasDiscount ? 'flex' : 'none';\n    if (hasDiscount) {\n      discountValue.textContent = `−${formatMoney(savingsAmount, currencyInfo)} (${discountPercent}% OFF)`;\n    }\n\n    // 区切り線\n    const divider = panel.querySelector('#qty-divider');\n    divider.style.display = hasDiscount ? 'block' : 'none';\n\n    // 合計金額\n    const totalValue = panel.querySelector('#qty-total-value');\n    const newTotalText = hasDiscount\n      ? `${formatMoney(discountedUnitPrice, currencyInfo)} × ${qty} = ${formatMoney(discountedTotal, currencyInfo)}`\n      : `${formatMoney(unitPrice, currencyInfo)} × ${qty} = ${formatMoney(originalTotal, currencyInfo)}`;\n    \n    if (totalValue.textContent !== newTotalText) {\n      totalValue.textContent = newTotalText;\n      totalValue.classList.remove('price-changed');\n      // アニメーションのリフローを強制\n      void totalValue.offsetWidth;\n      totalValue.classList.add('price-changed');\n    }\n\n    // まとめ買いメッセージ\n    const noDiscountMsg = panel.querySelector('#qty-no-discount');\n    noDiscountMsg.style.display = (!hasDiscount && qty === 1) ? 'block' : 'none';\n  }\n\n  function updateCartButton(btn, discountedTotal, currencyInfo) {\n    // Add to Cart ボタン内の金額表示を更新\n    const priceSpan = btn.querySelector('span[x-html=\"formatMoney(currentPrice)\"]');\n    if (priceSpan) {\n      priceSpan.textContent = formatMoney(discountedTotal, currencyInfo);\n      // Alpine.jsの再レンダリングを防ぐため、x-html属性を削除\n      priceSpan.removeAttribute('x-html');\n    }\n  }\n\n  // ========================================\n  // DOM Ready 待機\n  // ========================================\n  \n  if (document.readyState === 'loading') {\n    document.addEventListener('DOMContentLoaded', () => {\n      // Alpine.jsの初期化を待つ\n      setTimeout(init, 500);\n    });\n  } else {\n    // すでに読み込み済み\n    setTimeout(init, 500);\n  }\n\n})();\n</script>",
