    "custom_liquid_6qRpHj": {
      "type": "custom-liquid",
      "name": "t:sections.custom_liquid.name",
      "settings": {
        "title": "",
        "custom_liquid": "<!-- \n  ========================================\n  cutieTOKYO 数量割引表示スクリプト（多言語対応版）\n  ========================================\n  ※ 割引率の設定は DISCOUNT_TIERS 配列を編集してください。\n  ※ 日本語/英語の自動切り替えに対応しています。\n-->\n\n<style>\n  /* ===== 割引テーブル ===== */\n  .qty-discount-wrapper {\n    margin: 20px 0;\n    font-family: inherit;\n  }\n\n  .qty-discount-title {\n    font-size: 14px;\n    font-weight: 700;\n    margin-bottom: 10px;\n    color: inherit;\n    display: flex;\n    align-items: center;\n    gap: 6px;\n  }\n\n  .qty-discount-title::before {\n    content: '🏷️';\n  }\n\n  .qty-discount-table {\n    width: 100%;\n    border-collapse: collapse;\n    border-radius: 8px;\n    overflow: hidden;\n    border: 1px solid #e5e5e5;\n    font-size: 13px;\n  }\n\n  .qty-discount-table thead th {\n    background: #f5f5f5;\n    padding: 8px 12px;\n    text-align: center;\n    font-weight: 600;\n    font-size: 12px;\n    color: #666;\n    border-bottom: 1px solid #e5e5e5;\n  }\n\n  .qty-discount-table tbody td {\n    padding: 10px 12px;\n    text-align: center;\n    border-bottom: 1px solid #f0f0f0;\n    transition: all 0.2s ease;\n  }\n\n  .qty-discount-table tbody tr:last-child td {\n    border-bottom: none;\n  }\n\n  .qty-discount-table tbody tr.active-tier {\n    background: linear-gradient(135deg, #fff0f6 0%, #ffe8f0 100%);\n  }\n\n  .qty-discount-table tbody tr.active-tier td {\n    font-weight: 600;\n    color: #d63384;\n  }\n\n  .qty-discount-table .discount-badge {\n    display: inline-block;\n    padding: 2px 8px;\n    border-radius: 12px;\n    font-size: 11px;\n    font-weight: 700;\n    background: #f0f0f0;\n    color: #666;\n  }\n\n  .qty-discount-table tr.active-tier .discount-badge {\n    background: linear-gradient(135deg, #ff69b4 0%, #d63384 100%);\n    color: #fff;\n  }\n\n  /* ===== リアルタイム価格計算パネル ===== */\n  .qty-price-panel {\n    margin: 16px 0;\n    padding: 16px;\n    background: linear-gradient(135deg, #fafafa 0%, #f5f5f5 100%);\n    border-radius: 10px;\n    border: 1px solid #e8e8e8;\n    font-size: 14px;\n    transition: all 0.3s ease;\n  }\n\n  .qty-price-panel.has-discount {\n    background: linear-gradient(135deg, #fff8fc 0%, #fff0f6 100%);\n    border-color: #f5c2d7;\n  }\n\n  .qty-price-row {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    padding: 4px 0;\n  }\n\n  .qty-price-row.original-price {\n    color: #888;\n  }\n\n  .qty-price-row.original-price .qty-price-value {\n    text-decoration: line-through;\n  }\n\n  .qty-price-row.discount-amount {\n    color: #d63384;\n    font-weight: 600;\n  }\n\n  .qty-price-divider {\n    border: none;\n    border-top: 1px dashed #ddd;\n    margin: 8px 0;\n  }\n\n  .qty-price-row.total-price {\n    font-size: 18px;\n    font-weight: 700;\n    padding-top: 4px;\n  }\n\n  .qty-price-row.total-price .qty-price-value {\n    color: #d63384;\n  }\n\n  .qty-price-label {\n    display: flex;\n    align-items: center;\n    gap: 4px;\n  }\n\n  .qty-no-discount-msg {\n    text-align: center;\n    color: #999;\n    font-size: 13px;\n    padding: 4px 0;\n  }\n\n  .qty-hint-msg {\n    font-size: 12px;\n    color: #d63384;\n    margin-top: 6px;\n    display: flex;\n    align-items: center;\n    gap: 4px;\n  }\n\n  /* ===== ディスカウントコード入力欄 ===== */\n  .qty-coupon-wrapper {\n    margin: 16px 0;\n    padding: 14px 16px;\n    background: linear-gradient(135deg, #f8f8ff 0%, #f0f0ff 100%);\n    border-radius: 10px;\n    border: 1px solid #e0e0ee;\n  }\n\n  .qty-coupon-title {\n    font-size: 13px;\n    font-weight: 600;\n    margin-bottom: 8px;\n    color: #444;\n    display: flex;\n    align-items: center;\n    gap: 4px;\n  }\n\n  .qty-coupon-form {\n    display: flex;\n    gap: 8px;\n    align-items: center;\n  }\n\n  .qty-coupon-input {\n    flex: 1;\n    padding: 8px 12px;\n    border: 1px solid #d0d0d0;\n    border-radius: 6px;\n    font-size: 14px;\n    outline: none;\n    transition: border-color 0.2s ease;\n    text-transform: uppercase;\n  }\n\n  .qty-coupon-input:focus {\n    border-color: #d63384;\n    box-shadow: 0 0 0 2px rgba(214, 51, 132, 0.1);\n  }\n\n  .qty-coupon-input::placeholder {\n    text-transform: none;\n    color: #aaa;\n  }\n\n  .qty-coupon-apply-btn {\n    padding: 8px 16px;\n    background: linear-gradient(135deg, #ff69b4 0%, #d63384 100%);\n    color: #fff;\n    border: none;\n    border-radius: 6px;\n    font-size: 13px;\n    font-weight: 600;\n    cursor: pointer;\n    transition: all 0.2s ease;\n    white-space: nowrap;\n  }\n\n  .qty-coupon-apply-btn:hover {\n    transform: translateY(-1px);\n    box-shadow: 0 2px 8px rgba(214, 51, 132, 0.3);\n  }\n\n  .qty-coupon-apply-btn:disabled {\n    opacity: 0.6;\n    cursor: not-allowed;\n    transform: none;\n  }\n\n  .qty-coupon-msg {\n    font-size: 12px;\n    margin-top: 6px;\n    display: none;\n    align-items: center;\n    gap: 4px;\n  }\n\n  .qty-coupon-msg.success {\n    color: #28a745;\n    display: flex;\n  }\n\n  .qty-coupon-msg.error {\n    color: #dc3545;\n    display: flex;\n  }\n\n  @media (prefers-color-scheme: dark) {\n    .qty-coupon-wrapper {\n      background: linear-gradient(135deg, #1e1e2e 0%, #252535 100%);\n      border-color: #333;\n    }\n    .qty-coupon-title {\n      color: #ccc;\n    }\n    .qty-coupon-input {\n      background: #2a2a2a;\n      border-color: #444;\n      color: #eee;\n    }\n  }\n\n  /* ===== アニメーション ===== */\n  .qty-price-panel .qty-price-value {\n    transition: all 0.3s ease;\n  }\n\n  .qty-price-value.price-changed {\n    animation: priceFlash 0.4s ease;\n  }\n\n  @keyframes priceFlash {\n    0% { transform: scale(1); }\n    50% { transform: scale(1.08); color: #d63384; }\n    100% { transform: scale(1); }\n  }\n\n  /* ===== ダークモード対応 ===== */\n  @media (prefers-color-scheme: dark) {\n    .qty-discount-table {\n      border-color: #333;\n    }\n    .qty-discount-table thead th {\n      background: #2a2a2a;\n      color: #aaa;\n      border-bottom-color: #333;\n    }\n    .qty-discount-table tbody td {\n      border-bottom-color: #2a2a2a;\n    }\n    .qty-discount-table tbody tr.active-tier {\n      background: linear-gradient(135deg, #3d1a2e 0%, #2e1525 100%);\n    }\n    .qty-price-panel {\n      background: linear-gradient(135deg, #1e1e1e 0%, #252525 100%);\n      border-color: #333;\n    }\n    .qty-price-panel.has-discount {\n      background: linear-gradient(135deg, #2e1525 0%, #3d1a2e 100%);\n      border-color: #5a2040;\n    }\n  }\n</style>\n\n<script>\n(function() {\n  'use strict';\n\n  // ========================================\n  // 割引設定\n  // ========================================\n  var DISCOUNT_TIERS = [\n    { minQty: 1, discountPercent: 0 },\n    { minQty: 2, discountPercent: 5 },\n    { minQty: 3, discountPercent: 10 },\n    { minQty: 5, discountPercent: 15 }\n  ];\n\n  // ========================================\n  // 多言語テキスト定義\n  // ========================================\n  var TEXTS = {\n    ja: {\n      title: 'まとめ買い割引',\n      quantity: '数量',\n      discount: '割引率',\n      unitPrice: '単価',\n      regularPrice: '通常価格',\n      originalPrice: '定価',\n      bulkDiscount: '🌟 セット値引き額',\n      couponDiscount: '🎫 クーポン値引き額',\n      totalDiscount: '📣 値引き額合計',\n      totalPrice: '合計金額',\n      noDiscountMsg: '2個以上でまとめ買い割引が適用されます ✨',\n      couponAtCheckout: 'チェックアウト時に適用',\n      qtyHint: '💡 個数を増やすと割引が自動適用されます',\n      couponTitle: '🎁 クーポンコードをお持ちですか？',\n      couponPlaceholder: 'コードを入力',\n      couponApply: '適用',\n      couponApplying: '適用中...',\n      couponSuccess: '✅ クーポンが適用されました！',\n      couponError: '❌ コードを入力してください',\n      piece: '個',\n      piecePlural: '個',\n      pieceRange: function(from, to) { return from + '〜' + to + '個'; },\n      pieceFrom: function(n) { return n + '個〜'; },\n      pieceSingle: function(n) { return n + '個'; }\n    },\n    en: {\n      title: 'Bulk Discount',\n      quantity: 'Qty',\n      discount: 'Discount',\n      unitPrice: 'Unit Price',\n      regularPrice: 'Regular',\n      originalPrice: 'Original',\n      bulkDiscount: '🌟 Bulk Savings',\n      couponDiscount: '🎫 Coupon Savings',\n      totalDiscount: '📣 Total Savings',\n      totalPrice: 'Total',\n      noDiscountMsg: 'Buy 2 or more to get a bulk discount ✨',\n      couponAtCheckout: 'Applied at checkout',\n      qtyHint: '💡 Discount applied automatically with more items',\n      couponTitle: '🎁 Have a coupon code?',\n      couponPlaceholder: 'Enter code',\n      couponApply: 'Apply',\n      couponApplying: 'Applying...',\n      couponSuccess: '✅ Coupon applied!',\n      couponError: '❌ Please enter a code',\n      piece: '',\n      piecePlural: '',\n      pieceRange: function(from, to) { return from + ' - ' + to; },\n      pieceFrom: function(n) { return n + '+'; },\n      pieceSingle: function(n) { return '' + n; }\n    }\n  };\n\n  // ========================================\n  // 言語検出\n  // ========================================\n  function detectLanguage() {\n    var htmlLang = document.documentElement.lang || '';\n    if (htmlLang.toLowerCase().indexOf('ja') === 0) return 'ja';\n    if (htmlLang.toLowerCase().indexOf('en') === 0) return 'en';\n\n    try {\n      if (window.Shopify && window.Shopify.locale) {\n        if (window.Shopify.locale.indexOf('ja') === 0) return 'ja';\n        if (window.Shopify.locale.indexOf('en') === 0) return 'en';\n      }\n    } catch(e) {}\n\n    var path = window.location.pathname;\n    if (path.indexOf('/en/') !== -1 || path.indexOf('/en') === 0) return 'en';\n    if (path.indexOf('/ja/') !== -1 || path.indexOf('/ja') === 0) return 'ja';\n\n    var taxLabel = document.querySelector('.product__tax');\n    if (taxLabel) {\n      if (taxLabel.textContent.indexOf('Tax') !== -1) return 'en';\n      if (taxLabel.textContent.indexOf('税') !== -1) return 'ja';\n    }\n\n    return 'ja';\n  }\n\n  function getTexts() {\n    var lang = detectLanguage();\n    return TEXTS[lang] || TEXTS['ja'];\n  }\n\n  // ========================================\n  // 初期化\n  // ========================================\n  function init() {\n    var existing = document.querySelectorAll('.qty-discount-wrapper, .qty-price-panel');\n    existing.forEach(function(el) { el.remove(); });\n\n    var quantityInput = document.querySelector('input[name=\"quantity\"]');\n    var addToCartBtn = document.querySelector('.add-to-cart-btn');\n    var priceBlock = document.querySelector('.product-block-price');\n    var quantityBlock = document.querySelector('.product-block-quantity-selector');\n\n    if (!quantityInput || !addToCartBtn || !priceBlock) {\n      console.warn('[Qty Discount] Required DOM elements not found');\n      return;\n    }\n\n    var unitPrice = getUnitPrice();\n    if (!unitPrice) {\n      console.warn('[Qty Discount] Could not get unit price');\n      return;\n    }\n\n    var currencyInfo = getCurrencyInfo();\n    var texts = getTexts();\n\n    var discountTableEl = createDiscountTable(unitPrice, currencyInfo, texts);\n    var pricePanelEl = createPricePanel(texts);\n\n    var insertTarget = quantityBlock || priceBlock;\n    insertTarget.parentNode.insertBefore(discountTableEl, insertTarget.nextSibling);\n    addToCartBtn.parentNode.insertBefore(pricePanelEl, addToCartBtn);\n\n    // ========================================\n    // クーポン適用状態の管理（createCouponInputより先に実行）\n    // ========================================\n    var couponApplied = false;\n    var couponDiscountAmount = 0;\n    var urlParams = new URLSearchParams(window.location.search);\n    var appliedCode = urlParams.get('coupon_applied');\n    if (appliedCode) {\n      couponApplied = true;\n      localStorage.setItem('qty_coupon_code', appliedCode);\n      // URLからパラメータを除去（履歴を汚さない）\n      window.history.replaceState({}, '', window.location.pathname);\n    } else {\n      appliedCode = localStorage.getItem('qty_coupon_code');\n      if (appliedCode) {\n        couponApplied = true;\n      }\n    }\n\n    // 数量セレクタの横にヒントテキストを挿入\n    if (quantityBlock) {\n      var existingHint = document.querySelector('.qty-hint-msg');\n      if (!existingHint) {\n        var hintEl = document.createElement('div');\n        hintEl.className = 'qty-hint-msg';\n        hintEl.textContent = texts.qtyHint;\n        quantityBlock.appendChild(hintEl);\n      }\n    }\n\n    // ディスカウントコード入力欄を挿入（appliedCodeを渡す）\n    var existingCoupon = document.querySelector('.qty-coupon-wrapper');\n    if (!existingCoupon) {\n      var couponEl = createCouponInput(texts, appliedCode);\n      addToCartBtn.parentNode.insertBefore(couponEl, pricePanelEl);\n    }\n\n    // クーポン割引額をカートAPIで取得する関数\n    function fetchCouponDiscount(callback) {\n      if (!couponApplied) { callback(0); return; }\n      try {\n        var variantId = null;\n        if (window.ShopifyAnalytics && window.ShopifyAnalytics.meta && window.ShopifyAnalytics.meta.product) {\n          variantId = window.ShopifyAnalytics.meta.product.variants[0].id;\n        }\n        if (!variantId) { callback(0); return; }\n\n        // カートに商品を追加して割引額を確認\n        fetch('/cart/add.js', {\n          method: 'POST',\n          headers: { 'Content-Type': 'application/json' },\n          body: JSON.stringify({ id: variantId, quantity: 1 })\n        })\n        .then(function(r) { return r.json(); })\n        .then(function(addData) {\n          return fetch('/cart.js').then(function(r) { return r.json(); });\n        })\n        .then(function(cart) {\n          var discount = 0;\n          if (cart.items && cart.items.length > 0) {\n            var item = cart.items.find(function(i) { return i.variant_id === variantId; });\n            if (item) {\n              // 1個あたりの割引額を計算（line_level_discount_allocationsから）\n              if (item.line_level_discount_allocations && item.line_level_discount_allocations.length > 0) {\n                item.line_level_discount_allocations.forEach(function(d) {\n                  discount += d.amount / 100;\n                });\n                // カート内の数量で割って1個あたりの割引額にする\n                discount = discount / item.quantity;\n              }\n            }\n          }\n          // カートから削除\n          fetch('/cart/change.js', {\n            method: 'POST',\n            headers: { 'Content-Type': 'application/json' },\n            body: JSON.stringify({ id: variantId.toString(), quantity: 0 })\n          }).catch(function(){});\n          callback(discount);\n        })\n        .catch(function() { callback(0); });\n      } catch(e) { callback(0); }\n    }\n\n    // クーポン割引額を取得して反映\n    if (couponApplied) {\n      fetchCouponDiscount(function(discount) {\n        couponDiscountAmount = discount;\n        updatePricing();\n      });\n    }\n\n    function updatePricing() {\n      var qty = parseInt(quantityInput.value) || 1;\n      var tier = getActiveTier(qty);\n      var discountPercent = tier.discountPercent;\n      var discountedUnitPrice = unitPrice * (1 - discountPercent / 100);\n      var originalTotal = unitPrice * qty;\n      var discountedTotal = discountedUnitPrice * qty;\n      var savingsAmount = originalTotal - discountedTotal;\n\n      // クーポン割引を数量に応じてスケール\n      var scaledCouponDiscount = couponDiscountAmount * qty;\n\n      updateActiveRow(discountTableEl, qty);\n      updatePricePanel(pricePanelEl, {\n        qty: qty,\n        unitPrice: unitPrice,\n        discountPercent: discountPercent,\n        discountedUnitPrice: discountedUnitPrice,\n        originalTotal: originalTotal,\n        discountedTotal: discountedTotal,\n        savingsAmount: savingsAmount,\n        couponDiscount: scaledCouponDiscount,\n        couponApplied: couponApplied,\n        currencyInfo: currencyInfo,\n        texts: texts\n      });\n      updateCartButton(addToCartBtn, discountedTotal - scaledCouponDiscount, currencyInfo);\n    }\n\n    quantityInput.addEventListener('input', updatePricing);\n    quantityInput.addEventListener('change', updatePricing);\n\n    var buttons = quantityInput.parentElement.querySelectorAll('button');\n    buttons.forEach(function(btn) {\n      btn.addEventListener('click', function() {\n        setTimeout(updatePricing, 50);\n      });\n    });\n\n    var observer = new MutationObserver(function() {\n      setTimeout(updatePricing, 50);\n    });\n    observer.observe(quantityInput, { attributes: true, attributeFilter: ['value'] });\n\n    var lastQty = parseInt(quantityInput.value) || 1;\n    setInterval(function() {\n      var currentQty = parseInt(quantityInput.value) || 1;\n      if (currentQty !== lastQty) {\n        lastQty = currentQty;\n        updatePricing();\n      }\n    }, 200);\n\n    updatePricing();\n    console.log('[Qty Discount] Initialized - Unit: ' + formatMoney(unitPrice, currencyInfo) + ' Lang: ' + detectLanguage());\n  }\n\n  // ========================================\n  // 単価・通貨情報の取得\n  // ========================================\n  function getUnitPrice() {\n    try {\n      if (window.ShopifyAnalytics && window.ShopifyAnalytics.meta && window.ShopifyAnalytics.meta.product) {\n        var variant = window.ShopifyAnalytics.meta.product.variants[0];\n        if (variant && variant.price) {\n          return variant.price / 100;\n        }\n      }\n    } catch(e) {}\n\n    try {\n      var priceEl = document.querySelector('[data-product-price]');\n      if (priceEl) {\n        var priceText = priceEl.textContent.replace(/[^0-9.]/g, '');\n        return parseFloat(priceText);\n      }\n    } catch(e) {}\n\n    try {\n      var metaPrice = document.querySelector('meta[property=\"og:price:amount\"]');\n      if (metaPrice) {\n        return parseFloat(metaPrice.content);\n      }\n    } catch(e) {}\n\n    return null;\n  }\n\n  function getCurrencyInfo() {\n    var currency = 'SGD';\n    var moneyFormat = '${{amount}} SGD';\n\n    try {\n      if (window.Shopify && window.Shopify.currency && window.Shopify.currency.active) {\n        currency = window.Shopify.currency.active;\n      }\n    } catch(e) {}\n\n    try {\n      var metaCurrency = document.querySelector('meta[property=\"og:price:currency\"]');\n      if (metaCurrency) {\n        currency = metaCurrency.content;\n      }\n    } catch(e) {}\n\n    if (currency === 'JPY') {\n      moneyFormat = '\\u00a5{{amount}}';\n    } else if (currency === 'SGD') {\n      moneyFormat = '${{amount}} SGD';\n    } else if (currency === 'USD') {\n      moneyFormat = '${{amount}}';\n    }\n\n    return { currency: currency, moneyFormat: moneyFormat };\n  }\n\n  // ========================================\n  // 金額フォーマット\n  // ========================================\n  function formatMoney(amount, currencyInfo) {\n    var formatted;\n    if (currencyInfo.currency === 'JPY') {\n      formatted = Math.round(amount).toLocaleString('ja-JP');\n    } else {\n      formatted = amount.toFixed(2);\n    }\n    return currencyInfo.moneyFormat.replace('{{amount}}', formatted);\n  }\n\n  // ========================================\n  // 割引ティアの取得\n  // ========================================\n  function getActiveTier(qty) {\n    var activeTier = DISCOUNT_TIERS[0];\n    for (var i = 0; i < DISCOUNT_TIERS.length; i++) {\n      if (qty >= DISCOUNT_TIERS[i].minQty) {\n        activeTier = DISCOUNT_TIERS[i];\n      }\n    }\n    return activeTier;\n  }\n\n  // ========================================\n  // UI作成: 割引テーブル\n  // ========================================\n  function createDiscountTable(unitPrice, currencyInfo, texts) {\n    var wrapper = document.createElement('div');\n    wrapper.className = 'qty-discount-wrapper';\n\n    var title = document.createElement('div');\n    title.className = 'qty-discount-title';\n    title.textContent = texts.title;\n    wrapper.appendChild(title);\n\n    var table = document.createElement('table');\n    table.className = 'qty-discount-table';\n\n    var thead = document.createElement('thead');\n    thead.innerHTML = '<tr><th>' + texts.quantity + '</th><th>' + texts.discount + '</th><th>' + texts.unitPrice + '</th></tr>';\n    table.appendChild(thead);\n\n    var tbody = document.createElement('tbody');\n    DISCOUNT_TIERS.forEach(function(tier, index) {\n      var tr = document.createElement('tr');\n      tr.dataset.tierIndex = index;\n      tr.dataset.minQty = tier.minQty;\n\n      var discountedPrice = unitPrice * (1 - tier.discountPercent / 100);\n      var nextTier = DISCOUNT_TIERS[index + 1];\n      var qtyLabel;\n\n      if (nextTier) {\n        if (tier.minQty === nextTier.minQty - 1) {\n          qtyLabel = texts.pieceSingle(tier.minQty);\n        } else {\n          qtyLabel = texts.pieceRange(tier.minQty, nextTier.minQty - 1);\n        }\n      } else {\n        qtyLabel = texts.pieceFrom(tier.minQty);\n      }\n\n      if (tier.minQty === 1 && tier.discountPercent === 0) {\n        tr.innerHTML = '<td>' + qtyLabel + '</td><td><span class=\"discount-badge\">' + texts.regularPrice + '</span></td><td>' + formatMoney(discountedPrice, currencyInfo) + '</td>';\n      } else {\n        tr.innerHTML = '<td>' + qtyLabel + '</td><td><span class=\"discount-badge\">' + tier.discountPercent + '% OFF</span></td><td>' + formatMoney(discountedPrice, currencyInfo) + '</td>';\n      }\n\n      tbody.appendChild(tr);\n    });\n    table.appendChild(tbody);\n    wrapper.appendChild(table);\n\n    return wrapper;\n  }\n\n  // ========================================\n  // UI作成: 価格計算パネル（5行内訳表示）\n  // ========================================\n  function createPricePanel(texts) {\n    var panel = document.createElement('div');\n    panel.className = 'qty-price-panel';\n    panel.innerHTML = ''\n      // 定価\n      + '<div class=\"qty-price-row original-price\" id=\"qty-original-price\">'\n      + '<span class=\"qty-price-label\">' + texts.originalPrice + '</span>'\n      + '<span class=\"qty-price-value\" id=\"qty-original-value\"></span>'\n      + '</div>'\n      // セット値引き額\n      + '<div class=\"qty-price-row discount-amount\" id=\"qty-bulk-row\" style=\"display: none;\">'\n      + '<span class=\"qty-price-label\">' + texts.bulkDiscount + '</span>'\n      + '<span class=\"qty-price-value\" id=\"qty-bulk-value\"></span>'\n      + '</div>'\n      // クーポン値引き額\n      + '<div class=\"qty-price-row discount-amount\" id=\"qty-coupon-row\" style=\"display: none;\">'\n      + '<span class=\"qty-price-label\">' + texts.couponDiscount + '</span>'\n      + '<span class=\"qty-price-value\" id=\"qty-coupon-value\"></span>'\n      + '</div>'\n      // 値引き額合計\n      + '<div class=\"qty-price-row discount-amount\" id=\"qty-total-discount-row\" style=\"display: none;\">'\n      + '<span class=\"qty-price-label\" style=\"font-weight:700;\">' + texts.totalDiscount + '</span>'\n      + '<span class=\"qty-price-value\" id=\"qty-total-discount-value\" style=\"font-weight:700;\"></span>'\n      + '</div>'\n      + '<hr class=\"qty-price-divider\" id=\"qty-divider\">'\n      // 合計金額\n      + '<div class=\"qty-price-row total-price\">'\n      + '<span class=\"qty-price-label\">' + texts.totalPrice + '</span>'\n      + '<span class=\"qty-price-value\" id=\"qty-total-value\"></span>'\n      + '</div>'\n      + '<div class=\"qty-no-discount-msg\" id=\"qty-no-discount\" style=\"display: none;\">'\n      + texts.noDiscountMsg\n      + '</div>';\n    return panel;\n  }\n\n  // ========================================\n  // UI作成: クーポンコード入力欄\n  // ========================================\n  function createCouponInput(texts, appliedCode) {\n    var wrapper = document.createElement('div');\n    wrapper.className = 'qty-coupon-wrapper';\n\n    var titleEl = document.createElement('div');\n    titleEl.className = 'qty-coupon-title';\n    titleEl.textContent = texts.couponTitle;\n    wrapper.appendChild(titleEl);\n\n    var form = document.createElement('div');\n    form.className = 'qty-coupon-form';\n\n    var input = document.createElement('input');\n    input.type = 'text';\n    input.className = 'qty-coupon-input';\n    input.placeholder = texts.couponPlaceholder;\n    input.id = 'qty-coupon-code';\n    form.appendChild(input);\n\n    var applyBtn = document.createElement('button');\n    applyBtn.type = 'button';\n    applyBtn.className = 'qty-coupon-apply-btn';\n    applyBtn.textContent = texts.couponApply;\n    form.appendChild(applyBtn);\n    wrapper.appendChild(form);\n\n    var msgEl = document.createElement('div');\n    msgEl.className = 'qty-coupon-msg';\n    msgEl.id = 'qty-coupon-msg';\n    wrapper.appendChild(msgEl);\n\n    // クーポン適用済みの場合はUIを更新（appliedCodeはinit側から渡される）\n    if (appliedCode) {\n      input.value = appliedCode;\n      input.disabled = true;\n      input.style.opacity = '0.7';\n      applyBtn.disabled = true;\n      msgEl.className = 'qty-coupon-msg success';\n      msgEl.textContent = texts.couponSuccess;\n    }\n\n    // 適用ボタンのクリックイベント\n    applyBtn.addEventListener('click', function() {\n      var code = input.value.trim();\n      if (!code) {\n        msgEl.className = 'qty-coupon-msg error';\n        msgEl.textContent = texts.couponError;\n        return;\n      }\n\n      applyBtn.disabled = true;\n      applyBtn.textContent = texts.couponApplying;\n\n      // Shopifyの/discount/CODEエンドポイントにページ遷移して適用\n      // 適用後、現在のページにリダイレクトで戻ってくる\n      // 注意: pathnameは既にエンコード済みなので再エンコードしない\n      var currentPath = window.location.pathname;\n      window.location.href = '/discount/' + encodeURIComponent(code) + '?redirect=' + currentPath + '%3Fcoupon_applied%3D' + encodeURIComponent(code);\n    });\n\n    // Enterキーでも適用\n    input.addEventListener('keypress', function(e) {\n      if (e.key === 'Enter') {\n        applyBtn.click();\n      }\n    });\n\n    return wrapper;\n  }\n\n  // ========================================\n  // UI更新\n  // ========================================\n  function updateActiveRow(tableWrapper, qty) {\n    var rows = tableWrapper.querySelectorAll('tbody tr');\n    var activeIndex = 0;\n    DISCOUNT_TIERS.forEach(function(tier, index) {\n      if (qty >= tier.minQty) {\n        activeIndex = index;\n      }\n    });\n    rows.forEach(function(row, index) {\n      row.classList.toggle('active-tier', index === activeIndex);\n    });\n  }\n\n  function updatePricePanel(panel, data) {\n    var hasBulkDiscount = data.discountPercent > 0;\n    var couponAmount = data.couponDiscount || 0;\n    var hasCoupon = couponAmount > 0;\n    var hasAnyDiscount = hasBulkDiscount || hasCoupon;\n    panel.classList.toggle('has-discount', hasAnyDiscount);\n\n    // 定価行（常に表示）\n    var originalValue = panel.querySelector('#qty-original-value');\n    originalValue.textContent = formatMoney(data.unitPrice, data.currencyInfo) + ' \\u00d7 ' + data.qty + ' = ' + formatMoney(data.originalTotal, data.currencyInfo);\n\n    // セット値引き行\n    var bulkRow = panel.querySelector('#qty-bulk-row');\n    var bulkValue = panel.querySelector('#qty-bulk-value');\n    bulkRow.style.display = hasBulkDiscount ? 'flex' : 'none';\n    if (hasBulkDiscount) {\n      bulkValue.textContent = '\\u2212' + formatMoney(data.savingsAmount, data.currencyInfo) + ' (' + data.discountPercent + '% OFF)';\n    }\n\n    // クーポン値引き行\n    var couponRow = panel.querySelector('#qty-coupon-row');\n    var couponValue = panel.querySelector('#qty-coupon-value');\n    if (hasCoupon) {\n      couponRow.style.display = 'flex';\n      couponValue.textContent = '\\u2212' + formatMoney(couponAmount, data.currencyInfo);\n    } else if (data.couponApplied) {\n      couponRow.style.display = 'flex';\n      couponValue.textContent = data.texts.couponAtCheckout;\n      couponValue.style.fontSize = '12px';\n      couponValue.style.color = '#888';\n    } else {\n      couponRow.style.display = 'none';\n    }\n\n    // 値引き額合計行\n    var totalDiscountRow = panel.querySelector('#qty-total-discount-row');\n    var totalDiscountValue = panel.querySelector('#qty-total-discount-value');\n    var totalSavings = data.savingsAmount + couponAmount;\n    if (hasAnyDiscount) {\n      totalDiscountRow.style.display = 'flex';\n      totalDiscountValue.textContent = '\\u2212' + formatMoney(totalSavings, data.currencyInfo);\n    } else {\n      totalDiscountRow.style.display = 'none';\n    }\n\n    // 合計金額\n    var finalTotal = data.discountedTotal - couponAmount;\n    var totalValue = panel.querySelector('#qty-total-value');\n    var newTotalText = formatMoney(finalTotal, data.currencyInfo);\n\n    if (totalValue.textContent !== newTotalText) {\n      totalValue.textContent = newTotalText;\n      totalValue.classList.remove('price-changed');\n      void totalValue.offsetWidth;\n      totalValue.classList.add('price-changed');\n    }\n\n    // まとめ買いメッセージ\n    var noDiscountMsg = panel.querySelector('#qty-no-discount');\n    noDiscountMsg.style.display = (!hasAnyDiscount && data.qty === 1) ? 'block' : 'none';\n  }\n\n  function updateCartButton(btn, discountedTotal, currencyInfo) {\n    var priceSpans = btn.querySelectorAll('span.notranslate, span[x-html=\"formatMoney(currentPrice)\"]');\n    if (priceSpans.length > 0) {\n      priceSpans.forEach(function(span) {\n        span.textContent = formatMoney(discountedTotal, currencyInfo);\n        span.removeAttribute('x-html');\n        // 価格spanの前にあるダッシュ(–)span要素のテキストをスペースに置換\n        var prevEl = span.previousElementSibling;\n        if (prevEl && prevEl.tagName === 'SPAN' && prevEl.textContent.indexOf('\\u2013') !== -1) {\n          prevEl.innerHTML = '\\u00a0';\n        }\n      });\n    }\n  }\n\n  // ========================================\n  // DOM Ready 待機\n  // ========================================\n  if (document.readyState === 'loading') {\n    document.addEventListener('DOMContentLoaded', function() {\n      setTimeout(init, 500);\n    });\n  } else {\n    setTimeout(init, 500);\n  }\n\n})();\n</script>",
        "full_width": false,
        "color_scheme": ""
      }
    }
  },
