    "custom_liquid_FcxaMA": {
      "type": "custom-liquid",
      "name": "t:sections.custom_liquid.name",
      "settings": {
        "title": "",
        "custom_liquid": "<!-- \n  ========================================\n  cutieTOKYO 数量割引表示スクリプト（多言語対応版）\n  ========================================\n  Shopify管理画面 → オンラインストア → テーマ → カスタマイズ →\n  商品ページ → 「カスタムLiquid」セクションに、このコードを貼り付けてください。\n  \n  ※ 割引率の設定は DISCOUNT_TIERS 配列を編集してください。\n  ※ 日本語/英語の自動切り替えに対応しています。\n-->\n\n<style>\n  /* ===== 割引テーブル ===== */\n  .qty-discount-wrapper {\n    margin: 20px 0;\n    font-family: inherit;\n  }\n\n  .qty-discount-title {\n    font-size: 14px;\n    font-weight: 700;\n    margin-bottom: 10px;\n    color: inherit;\n    display: flex;\n    align-items: center;\n    gap: 6px;\n  }\n\n  .qty-discount-title::before {\n    content: '🏷️';\n  }\n\n  .qty-discount-table {\n    width: 100%;\n    border-collapse: collapse;\n    border-radius: 8px;\n    overflow: hidden;\n    border: 1px solid #e5e5e5;\n    font-size: 13px;\n  }\n\n  .qty-discount-table thead th {\n    background: #f5f5f5;\n    padding: 8px 12px;\n    text-align: center;\n    font-weight: 600;\n    font-size: 12px;\n    color: #666;\n    border-bottom: 1px solid #e5e5e5;\n  }\n\n  .qty-discount-table tbody td {\n    padding: 10px 12px;\n    text-align: center;\n    border-bottom: 1px solid #f0f0f0;\n    transition: all 0.2s ease;\n  }\n\n  .qty-discount-table tbody tr:last-child td {\n    border-bottom: none;\n  }\n\n  .qty-discount-table tbody tr.active-tier {\n    background: linear-gradient(135deg, #fff0f6 0%, #ffe8f0 100%);\n  }\n\n  .qty-discount-table tbody tr.active-tier td {\n    font-weight: 600;\n    color: #d63384;\n  }\n\n  .qty-discount-table .discount-badge {\n    display: inline-block;\n    padding: 2px 8px;\n    border-radius: 12px;\n    font-size: 11px;\n    font-weight: 700;\n    background: #f0f0f0;\n    color: #666;\n  }\n\n  .qty-discount-table tr.active-tier .discount-badge {\n    background: linear-gradient(135deg, #ff69b4 0%, #d63384 100%);\n    color: #fff;\n  }\n\n  /* ===== リアルタイム価格計算パネル ===== */\n  .qty-price-panel {\n    margin: 16px 0;\n    padding: 16px;\n    background: linear-gradient(135deg, #fafafa 0%, #f5f5f5 100%);\n    border-radius: 10px;\n    border: 1px solid #e8e8e8;\n    font-size: 14px;\n    transition: all 0.3s ease;\n  }\n\n  .qty-price-panel.has-discount {\n    background: linear-gradient(135deg, #fff8fc 0%, #fff0f6 100%);\n    border-color: #f5c2d7;\n  }\n\n  .qty-price-row {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    padding: 4px 0;\n  }\n\n  .qty-price-row.original-price {\n    color: #888;\n  }\n\n  .qty-price-row.original-price .qty-price-value {\n    text-decoration: line-through;\n  }\n\n  .qty-price-row.discount-amount {\n    color: #d63384;\n    font-weight: 600;\n  }\n\n  .qty-price-divider {\n    border: none;\n    border-top: 1px dashed #ddd;\n    margin: 8px 0;\n  }\n\n  .qty-price-row.total-price {\n    font-size: 18px;\n    font-weight: 700;\n    padding-top: 4px;\n  }\n\n  .qty-price-row.total-price .qty-price-value {\n    color: #d63384;\n  }\n\n  .qty-price-label {\n    display: flex;\n    align-items: center;\n    gap: 4px;\n  }\n\n  .qty-no-discount-msg {\n    text-align: center;\n    color: #999;\n    font-size: 13px;\n    padding: 4px 0;\n  }\n\n  /* ===== アニメーション ===== */\n  .qty-price-panel .qty-price-value {\n    transition: all 0.3s ease;\n  }\n\n  .qty-price-value.price-changed {\n    animation: priceFlash 0.4s ease;\n  }\n\n  @keyframes priceFlash {\n    0% {\n      transform: scale(1);\n    }\n\n    50% {\n      transform: scale(1.08);\n      color: #d63384;\n    }\n\n    100% {\n      transform: scale(1);\n    }\n  }\n\n  /* ===== カート追加後のカートボタン ===== */\n  .qty-go-to-cart-btn {\n    display: block;\n    width: 100%;\n    padding: 14px 20px;\n    background: linear-gradient(135deg, #7ec8e3 0%, #4da8da 100%);\n    color: #fff;\n    text-decoration: none;\n    border-radius: 8px;\n    font-size: 16px;\n    font-weight: 700;\n    text-align: center;\n    transition: all 0.3s ease;\n    margin-top: 8px;\n  }\n\n  .qty-go-to-cart-btn:hover {\n    background: linear-gradient(135deg, #9dd5ec 0%, #3a8fbf 100%);\n    transform: translateY(-1px);\n    box-shadow: 0 4px 12px rgba(77, 168, 218, 0.4);\n    color: #fff;\n    text-decoration: none;\n  }\n\n\n  /* ===== ダークモード対応 ===== */\n  @media (prefers-color-scheme: dark) {\n    .qty-discount-table {\n      border-color: #333;\n    }\n\n    .qty-discount-table thead th {\n      background: #2a2a2a;\n      color: #aaa;\n      border-bottom-color: #333;\n    }\n\n    .qty-discount-table tbody td {\n      border-bottom-color: #2a2a2a;\n    }\n\n    .qty-discount-table tbody tr.active-tier {\n      background: linear-gradient(135deg, #3d1a2e 0%, #2e1525 100%);\n    }\n\n    .qty-price-panel {\n      background: linear-gradient(135deg, #1e1e1e 0%, #252525 100%);\n      border-color: #333;\n    }\n\n    .qty-price-panel.has-discount {\n      background: linear-gradient(135deg, #2e1525 0%, #3d1a2e 100%);\n      border-color: #5a2040;\n    }\n  }\n</style>\n\n<script>\n  (function () {\n    'use strict';\n\n    // ========================================\n    // 割引設定 - ここを編集して割引率を変更\n    // ========================================\n    var DISCOUNT_TIERS = [\n      { minQty: 1, discountPercent: 0 },\n      { minQty: 2, discountPercent: 5 },\n      { minQty: 3, discountPercent: 10 },\n      { minQty: 5, discountPercent: 15 }\n    ];\n\n    // ========================================\n    // 多言語テキスト定義\n    // ========================================\n    var TEXTS = {\n      ja: {\n        title: 'まとめ買い割引',\n        quantity: '数量',\n        discount: '割引率',\n        unitPrice: '単価',\n        regularPrice: '通常価格',\n        originalPrice: '定価',\n        discountAmount: '📣 値引き額',\n        totalPrice: '合計金額',\n        noDiscountMsg: '2個以上でまとめ買い割引が適用されます ✨',\n        hintMsg: '💡 個数を増やすと割引が自動適用されます',\n        cartButtonLabel: '🛒 カートを見る',\n        piece: '個',\n        piecePlural: '個',\n        pieceRange: function (from, to) { return from + '〜' + to + '個'; },\n        pieceFrom: function (n) { return n + '個〜'; },\n        pieceSingle: function (n) { return n + '個'; }\n      },\n      en: {\n        title: 'Bulk Discount',\n        quantity: 'Qty',\n        discount: 'Discount',\n        unitPrice: 'Unit Price',\n        regularPrice: 'Regular',\n        originalPrice: 'Original',\n        discountAmount: '📣 Savings',\n        totalPrice: 'Total',\n        noDiscountMsg: 'Buy 2 or more to get a bulk discount ✨',\n        hintMsg: '💡 Increase quantity for automatic discounts',\n        cartButtonLabel: '🛒 View Cart',\n        piece: '',\n        piecePlural: '',\n        pieceRange: function (from, to) { return from + ' - ' + to; },\n        pieceFrom: function (n) { return n + '+'; },\n        pieceSingle: function (n) { return '' + n; }\n      }\n    };\n\n    // ========================================\n    // 言語検出\n    // ========================================\n    function detectLanguage() {\n      // 方法1: html要素のlang属性を確認\n      var htmlLang = document.documentElement.lang || '';\n      if (htmlLang.toLowerCase().indexOf('ja') === 0) return 'ja';\n      if (htmlLang.toLowerCase().indexOf('en') === 0) return 'en';\n\n      // 方法2: Shopifyのlocale情報を確認\n      try {\n        if (window.Shopify && window.Shopify.locale) {\n          if (window.Shopify.locale.indexOf('ja') === 0) return 'ja';\n          if (window.Shopify.locale.indexOf('en') === 0) return 'en';\n        }\n      } catch (e) { }\n\n      // 方法3: URLのパスを確認（/en/や/ja/など）\n      var path = window.location.pathname;\n      if (path.indexOf('/en/') !== -1 || path.indexOf('/en') === 0) return 'en';\n      if (path.indexOf('/ja/') !== -1 || path.indexOf('/ja') === 0) return 'ja';\n\n      // 方法4: ページ内のテキストを確認\n      var taxLabel = document.querySelector('.product__tax');\n      if (taxLabel) {\n        if (taxLabel.textContent.indexOf('Tax') !== -1) return 'en';\n        if (taxLabel.textContent.indexOf('税') !== -1) return 'ja';\n      }\n\n      // デフォルトは日本語\n      return 'ja';\n    }\n\n    function getTexts() {\n      var lang = detectLanguage();\n      return TEXTS[lang] || TEXTS['ja'];\n    }\n\n    // ========================================\n    // 初期化\n    // ========================================\n    function init() {\n      // 既存の割引要素があれば削除（再初期化対応）\n      var existing = document.querySelectorAll('.qty-discount-wrapper, .qty-price-panel');\n      existing.forEach(function (el) { el.remove(); });\n\n      var quantityInput = document.querySelector('input[name=\"quantity\"]');\n      var addToCartBtn = document.querySelector('.add-to-cart-btn');\n      var priceBlock = document.querySelector('.product-block-price');\n      var quantityBlock = document.querySelector('.product-block-quantity-selector');\n\n      if (!quantityInput || !addToCartBtn || !priceBlock) {\n        console.warn('[Qty Discount] Required DOM elements not found');\n        return;\n      }\n\n      var unitPrice = getUnitPrice();\n      if (!unitPrice) {\n        console.warn('[Qty Discount] Could not get unit price');\n        return;\n      }\n\n      var currencyInfo = getCurrencyInfo();\n      var texts = getTexts();\n\n      var discountTableEl = createDiscountTable(unitPrice, currencyInfo, texts);\n      var pricePanelEl = createPricePanel(texts);\n\n      var insertTarget = quantityBlock || priceBlock;\n      insertTarget.parentNode.insertBefore(discountTableEl, insertTarget.nextSibling);\n      addToCartBtn.parentNode.insertBefore(pricePanelEl, addToCartBtn);\n\n      // 数量セレクタの横にヒントテキストを挿入\n      if (quantityBlock) {\n        var existingHint = document.querySelector('.qty-hint-msg');\n        if (!existingHint) {\n          var hintMsg = document.createElement('div');\n          hintMsg.className = 'qty-hint-msg';\n          hintMsg.textContent = texts.hintMsg;\n          quantityBlock.appendChild(hintMsg);\n        }\n      }\n\n      // カート追加後の通知メッセージをカートボタンに置き換え\n      var cartNotice = document.querySelector('[x-show=\"addedToCart\"]');\n      if (cartNotice) {\n        cartNotice.innerHTML = '<a href=\"/cart\" class=\"qty-go-to-cart-btn\">' + texts.cartButtonLabel + '</a>';\n      }\n\n\n      function updatePricing() {\n        var qty = parseInt(quantityInput.value) || 1;\n        var tier = getActiveTier(qty);\n        var discountPercent = tier.discountPercent;\n        var discountedUnitPrice = unitPrice * (1 - discountPercent / 100);\n        var originalTotal = unitPrice * qty;\n        var discountedTotal = discountedUnitPrice * qty;\n        var savingsAmount = originalTotal - discountedTotal;\n\n\n        updateActiveRow(discountTableEl, qty);\n        updatePricePanel(pricePanelEl, {\n          qty: qty,\n          unitPrice: unitPrice,\n          discountPercent: discountPercent,\n          discountedUnitPrice: discountedUnitPrice,\n          originalTotal: originalTotal,\n          discountedTotal: discountedTotal,\n          savingsAmount: savingsAmount,\n          currencyInfo: currencyInfo,\n          texts: texts\n        });\n        updateCartButton(addToCartBtn, discountedTotal, currencyInfo);\n      }\n\n      quantityInput.addEventListener('input', updatePricing);\n      quantityInput.addEventListener('change', updatePricing);\n\n      var buttons = quantityInput.parentElement.querySelectorAll('button');\n      buttons.forEach(function (btn) {\n        btn.addEventListener('click', function () {\n          setTimeout(updatePricing, 50);\n        });\n      });\n\n      var observer = new MutationObserver(function () {\n        setTimeout(updatePricing, 50);\n      });\n      observer.observe(quantityInput, { attributes: true, attributeFilter: ['value'] });\n\n      var lastQty = parseInt(quantityInput.value) || 1;\n      setInterval(function () {\n        var currentQty = parseInt(quantityInput.value) || 1;\n        if (currentQty !== lastQty) {\n          lastQty = currentQty;\n          updatePricing();\n        }\n      }, 200);\n\n      updatePricing();\n      console.log('[Qty Discount] Initialized - Unit: ' + formatMoney(unitPrice, currencyInfo) + ' Lang: ' + detectLanguage());\n    }\n\n    // ========================================\n    // 単価・通貨情報の取得\n    // ========================================\n    function getUnitPrice() {\n      try {\n        if (window.ShopifyAnalytics && window.ShopifyAnalytics.meta && window.ShopifyAnalytics.meta.product) {\n          var variant = window.ShopifyAnalytics.meta.product.variants[0];\n          if (variant && variant.price) {\n            return variant.price / 100;\n          }\n        }\n      } catch (e) { }\n\n      try {\n        var priceEl = document.querySelector('[data-product-price]');\n        if (priceEl) {\n          var priceText = priceEl.textContent.replace(/[^0-9.]/g, '');\n          return parseFloat(priceText);\n        }\n      } catch (e) { }\n\n      try {\n        var metaPrice = document.querySelector('meta[property=\"og:price:amount\"]');\n        if (metaPrice) {\n          return parseFloat(metaPrice.content);\n        }\n      } catch (e) { }\n\n      return null;\n    }\n\n    function getCurrencyInfo() {\n      var currency = 'SGD';\n      var moneyFormat = '${{amount}} SGD';\n\n      try {\n        if (window.Shopify && window.Shopify.currency && window.Shopify.currency.active) {\n          currency = window.Shopify.currency.active;\n        }\n      } catch (e) { }\n\n      try {\n        var metaCurrency = document.querySelector('meta[property=\"og:price:currency\"]');\n        if (metaCurrency) {\n          currency = metaCurrency.content;\n        }\n      } catch (e) { }\n\n      if (currency === 'JPY') {\n        moneyFormat = '\\u00a5{{amount}}';\n      } else if (currency === 'SGD') {\n        moneyFormat = '${{amount}} SGD';\n      } else if (currency === 'USD') {\n        moneyFormat = '${{amount}}';\n      }\n\n      return { currency: currency, moneyFormat: moneyFormat };\n    }\n\n    // ========================================\n    // 金額フォーマット\n    // ========================================\n    function formatMoney(amount, currencyInfo) {\n      var formatted;\n      if (currencyInfo.currency === 'JPY') {\n        formatted = Math.round(amount).toLocaleString('ja-JP');\n      } else {\n        formatted = amount.toFixed(2);\n      }\n      return currencyInfo.moneyFormat.replace('{{amount}}', formatted);\n    }\n\n    // ========================================\n    // 割引ティアの取得\n    // ========================================\n    function getActiveTier(qty) {\n      var activeTier = DISCOUNT_TIERS[0];\n      for (var i = 0; i < DISCOUNT_TIERS.length; i++) {\n        if (qty >= DISCOUNT_TIERS[i].minQty) {\n          activeTier = DISCOUNT_TIERS[i];\n        }\n      }\n      return activeTier;\n    }\n\n    // ========================================\n    // UI作成: 割引テーブル\n    // ========================================\n    function createDiscountTable(unitPrice, currencyInfo, texts) {\n      var wrapper = document.createElement('div');\n      wrapper.className = 'qty-discount-wrapper';\n\n      var title = document.createElement('div');\n      title.className = 'qty-discount-title';\n      title.textContent = texts.title;\n      wrapper.appendChild(title);\n\n      var table = document.createElement('table');\n      table.className = 'qty-discount-table';\n\n      var thead = document.createElement('thead');\n      thead.innerHTML = '<tr><th>' + texts.quantity + '</th><th>' + texts.discount + '</th><th>' + texts.unitPrice + '</th></tr>';\n      table.appendChild(thead);\n\n      var tbody = document.createElement('tbody');\n      DISCOUNT_TIERS.forEach(function (tier, index) {\n        var tr = document.createElement('tr');\n        tr.dataset.tierIndex = index;\n        tr.dataset.minQty = tier.minQty;\n\n        var discountedPrice = unitPrice * (1 - tier.discountPercent / 100);\n        var nextTier = DISCOUNT_TIERS[index + 1];\n        var qtyLabel;\n\n        if (nextTier) {\n          if (tier.minQty === nextTier.minQty - 1) {\n            qtyLabel = texts.pieceSingle(tier.minQty);\n          } else {\n            qtyLabel = texts.pieceRange(tier.minQty, nextTier.minQty - 1);\n          }\n        } else {\n          qtyLabel = texts.pieceFrom(tier.minQty);\n        }\n\n        if (tier.minQty === 1 && tier.discountPercent === 0) {\n          tr.innerHTML = '<td>' + qtyLabel + '</td><td><span class=\"discount-badge\">' + texts.regularPrice + '</span></td><td>' + formatMoney(discountedPrice, currencyInfo) + '</td>';\n        } else {\n          tr.innerHTML = '<td>' + qtyLabel + '</td><td><span class=\"discount-badge\">' + tier.discountPercent + '% OFF</span></td><td>' + formatMoney(discountedPrice, currencyInfo) + '</td>';\n        }\n\n        tbody.appendChild(tr);\n      });\n      table.appendChild(tbody);\n      wrapper.appendChild(table);\n\n      return wrapper;\n    }\n\n    // ========================================\n    // UI作成: 価格計算パネル\n    // ========================================\n    function createPricePanel(texts) {\n      var panel = document.createElement('div');\n      panel.className = 'qty-price-panel';\n      panel.innerHTML = '<div class=\"qty-price-row original-price\" id=\"qty-original-price\" style=\"display: none;\">'\n        + '<span class=\"qty-price-label\">' + texts.originalPrice + '</span>'\n        + '<span class=\"qty-price-value\" id=\"qty-original-value\"></span>'\n        + '</div>'\n        + '<div class=\"qty-price-row discount-amount\" id=\"qty-discount-row\" style=\"display: none;\">'\n        + '<span class=\"qty-price-label\">' + texts.discountAmount + '</span>'\n        + '<span class=\"qty-price-value\" id=\"qty-discount-value\"></span>'\n        + '</div>'\n        + '<hr class=\"qty-price-divider\" id=\"qty-divider\" style=\"display: none;\">'\n        + '<div class=\"qty-price-row total-price\">'\n        + '<span class=\"qty-price-label\">' + texts.totalPrice + '</span>'\n        + '<span class=\"qty-price-value\" id=\"qty-total-value\"></span>'\n        + '</div>'\n        + '<div class=\"qty-no-discount-msg\" id=\"qty-no-discount\" style=\"display: none;\">'\n        + texts.noDiscountMsg\n        + '</div>';\n      return panel;\n    }\n\n    // ========================================\n    // UI更新\n    // ========================================\n    function updateActiveRow(tableWrapper, qty) {\n      var rows = tableWrapper.querySelectorAll('tbody tr');\n      var activeIndex = 0;\n      DISCOUNT_TIERS.forEach(function (tier, index) {\n        if (qty >= tier.minQty) {\n          activeIndex = index;\n        }\n      });\n      rows.forEach(function (row, index) {\n        row.classList.toggle('active-tier', index === activeIndex);\n      });\n    }\n\n    function updatePricePanel(panel, data) {\n      var hasDiscount = data.discountPercent > 0;\n      panel.classList.toggle('has-discount', hasDiscount);\n\n      var originalRow = panel.querySelector('#qty-original-price');\n      var originalValue = panel.querySelector('#qty-original-value');\n      originalRow.style.display = hasDiscount ? 'flex' : 'none';\n      if (hasDiscount) {\n        originalValue.textContent = formatMoney(data.unitPrice, data.currencyInfo) + ' \\u00d7 ' + data.qty + ' = ' + formatMoney(data.originalTotal, data.currencyInfo);\n      }\n\n      var discountRow = panel.querySelector('#qty-discount-row');\n      var discountValue = panel.querySelector('#qty-discount-value');\n      discountRow.style.display = hasDiscount ? 'flex' : 'none';\n      if (hasDiscount) {\n        discountValue.textContent = '\\u2212' + formatMoney(data.savingsAmount, data.currencyInfo) + ' (' + data.discountPercent + '% OFF)';\n      }\n\n      var divider = panel.querySelector('#qty-divider');\n      divider.style.display = hasDiscount ? 'block' : 'none';\n\n      var totalValue = panel.querySelector('#qty-total-value');\n      var newTotalText = hasDiscount\n        ? formatMoney(data.discountedUnitPrice, data.currencyInfo) + ' \\u00d7 ' + data.qty + ' = ' + formatMoney(data.discountedTotal, data.currencyInfo)\n        : formatMoney(data.unitPrice, data.currencyInfo) + ' \\u00d7 ' + data.qty + ' = ' + formatMoney(data.originalTotal, data.currencyInfo);\n\n      if (totalValue.textContent !== newTotalText) {\n        totalValue.textContent = newTotalText;\n        totalValue.classList.remove('price-changed');\n        void totalValue.offsetWidth;\n        totalValue.classList.add('price-changed');\n      }\n\n      var noDiscountMsg = panel.querySelector('#qty-no-discount');\n      noDiscountMsg.style.display = (!hasDiscount && data.qty === 1) ? 'block' : 'none';\n    }\n\n    function updateCartButton(btn, discountedTotal, currencyInfo) {\n      var priceSpans = btn.querySelectorAll('span.notranslate, span[x-html=\"formatMoney(currentPrice)\"]');\n      if (priceSpans.length > 0) {\n        priceSpans.forEach(function (span) {\n          span.textContent = formatMoney(discountedTotal, currencyInfo);\n          span.removeAttribute('x-html');\n        });\n      }\n    }\n\n    // ========================================\n    // DOM Ready 待機\n    // ========================================\n    if (document.readyState === 'loading') {\n      document.addEventListener('DOMContentLoaded', function () {\n        setTimeout(init, 500);\n      });\n    } else {\n      setTimeout(init, 500);\n    }\n\n  })();\n</script>",
        "full_width": false,
        "color_scheme": ""
      }
    }
